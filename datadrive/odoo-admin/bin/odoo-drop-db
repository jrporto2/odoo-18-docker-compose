#!/bin/bash
set -e

DB="$1"
PG_CONTAINER="c_postgres"
PROTECTED="DESTINATION/datadrive/odoo-admin/config/protected_dbs.conf"
LOG="DESTINATION/datadrive/odoo-admin/logs/actions.log"

if grep -qx "$DB" "$PROTECTED"; then
  echo "Base protegida: $DB"
  exit 1
fi

read -p "¿Seguro que deseas eliminar $DB? (yes): " CONFIRM
[[ "$CONFIRM" == "yes" ]] || exit 1

echo "$(date) DROP_DB $DB" >> "$LOG"

docker exec "$PG_CONTAINER" dropdb -U odoo "$DB"

echo "Base eliminada"
