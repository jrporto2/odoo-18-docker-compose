#!/bin/bash
set -e

DB="$1"
DATE=$(date +%F_%H-%M)
BACKUP_DIR="DESTINATION/datadrive/odoo-admin/backups"
LOG="DESTINATION/datadrive/odoo-admin/logs/actions.log"
PG_CONTAINER="c_postgres"

mkdir -p "$BACKUP_DIR"

echo "$(date) BACKUP_DB $DB" >> "$LOG"

docker exec "$PG_CONTAINER" \
  pg_dump -U odoo "$DB" \
  > "$BACKUP_DIR/$DB-$DATE.sql"

echo "Backup generado: $BACKUP_DIR/$DB-$DATE.sql"
