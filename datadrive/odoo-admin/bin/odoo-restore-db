#!/bin/bash
set -e

DB="$1"
FILE="$2"
PG_CONTAINER="c_postgres"
LOG="DESTINATION/datadrive/odoo-admin/logs/actions.log"

if [[ ! -f "$FILE" ]]; then
  echo "Backup no existe"
  exit 1
fi

echo "$(date) RESTORE_DB $DB FROM $FILE" >> "$LOG"

docker exec "$PG_CONTAINER" dropdb -U odoo --if-exists "$DB"
docker exec "$PG_CONTAINER" createdb -U odoo "$DB"

cat "$FILE" | docker exec -i "$PG_CONTAINER" psql -U odoo "$DB"

echo "Restauración completada"
