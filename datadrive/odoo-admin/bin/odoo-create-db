#!/bin/bash
set -e

DB="$1"
LOG="./datadrive/odoo-admin/logs/actions.log"
ODOO_CONTAINER="c_odoo"
PG_CONTAINER="c_postgres"

if [[ ! "$DB" =~ ^[a-zA-Z0-9_]{3,30}$ ]]; then
  echo "Nombre de base inválido"
  exit 1
fi

echo "$(date) CREATE_DB $DB" >> "$LOG"

# Crear BD en PostgreSQL
docker exec "$PG_CONTAINER" createdb -U odoo "$DB"

# Inicializar Odoo
docker exec "$ODOO_CONTAINER" odoo \
  -d "$DB" \
  -i base \
  --without-demo=all \
  --stop-after-init

echo "Base creada correctamente: $DB"
